# --- Database ---
# Used by both the app and Alembic. asyncpg driver for the app, psycopg/asyncpg for Alembic env.py.
DATABASE_URL=postgresql+asyncpg://archive:archive@db:5432/archive

# Postgres bootstrap (compose)
POSTGRES_USER=archive
POSTGRES_PASSWORD=archive
POSTGRES_DB=archive

# --- API ---
# Comma-separated list of accepted API keys. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=dev-key-change-me

# --- Observability ---
LOG_LEVEL=INFO
ENABLE_METRICS=false

# --- Limits ---
RATE_LIMIT_PER_MINUTE=120
MAX_CONTENT_LENGTH=32768

# --- CORS (off by default; comma-separated origins) ---
CORS_ORIGINS=

# --- LLM stack (only used with `make llm-up` / `--profile llm`) ---
# Smallest viable Gemma 3 model. Alternatives:
#   gemma3:270m   (~290MB, very small but coherent)
#   qwen2.5:0.5b  (~500MB)
#   llama3.2:1b   (~1.3GB)
LLM_MODEL=gemma3:1b
LLM_TEMPERATURE=0.7
CHAT_PORT=8001
OLLAMA_PORT=11434
